    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "@types/selenium-webdriver": "^4.35.6",
    "autoprefixer": "^10.4.21",
    "chai": "^6.2.2",
    "esbuild": "^0.25.0",
    "mocha": "^11.7.6",
    "selenium-webdriver": "^4.44.0",
